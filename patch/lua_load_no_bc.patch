   ls->pe = ls->p = NULL;
@@ -413,33 +412,6 @@ int lj_lex_setup(lua_State *L, LexState *ls)
   ls->endmark = 0;
   ls->fr2 = LJ_FR2;  /* Generate native bytecode by default. */
   lex_next(ls);  /* Read-ahead first char. */
-  if (ls->c == 0xef && ls->p + 2 <= ls->pe && (uint8_t)ls->p[0] == 0xbb &&
