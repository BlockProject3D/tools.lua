-    do {
-      lex_next(ls);
-      if (ls->c == LEX_EOF) return 0;
-    } while (!lex_iseol(ls));
-    lex_newline(ls);
-    header = 1;
-  }
-  if (ls->c == LUA_SIGNATURE[0]) {  /* Bytecode dump. */
-    if (header) {
